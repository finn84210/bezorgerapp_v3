<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bezorgerapp_v3.Pages.RoutePage"
             Title="Leverroute">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Leverroute" Style="{StaticResource PageTitle}" />
            <Label x:Name="RouteInfoLabel" Style="{StaticResource MutedText}" />
            <Border Style="{StaticResource InfoPanel}">
                <Label Text="Open de route, kies een bezorgoptie en zet de bestelling op afgeleverd zodra je klaar bent."
                       Style="{StaticResource MutedText}" />
            </Border>

            <VerticalStackLayout x:Name="RouteList" Spacing="12" />

            <Border Style="{StaticResource AppCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Route navigatie" Style="{StaticResource CardTitle}" />
                    <Label Text="Je kunt altijd terug naar de vorige stap of opnieuw naar het overzicht."
                           Style="{StaticResource MutedText}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="10">
                        <Button Text="Terug naar pakketten"
                                Clicked="OnBackToPackagesClicked" />
                        <Button Grid.Column="1"
                                Text="Naar bestellingen"
                                Clicked="OnBackToOrdersClicked" />
                        <Button Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Text="Route klaar"
                                Style="{StaticResource PrimaryButton}"
                                Clicked="OnRouteDoneClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
