<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bezorgerapp_v3.Pages.RoutePage"
             Title="Leverroute">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Leverroute" Style="{StaticResource PageTitle}" />
            <Label x:Name="RouteInfoLabel" Style="{StaticResource MutedText}" />
            <Border Style="{StaticResource InfoPanel}">
                <Label Text="Open de route, kies een bezorgoptie en zet de bestelling op afgeleverd zodra je klaar bent."
                       Style="{StaticResource MutedText}" />
            </Border>

            <VerticalStackLayout x:Name="RouteList" Spacing="12" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
