<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bezorgerapp_v3.Pages.PackagesPage"
             Title="Pakketten controleren">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Pakketten controleren" Style="{StaticResource PageTitle}" />
            <Label x:Name="ProgressLabel" Style="{StaticResource MutedText}" />

            <ProgressBar x:Name="PackageProgress" Progress="0" />

            <VerticalStackLayout x:Name="PackagesList" Spacing="10" />

            <Label x:Name="WarningLabel"
                   IsVisible="False"
                   Style="{StaticResource ErrorText}" />

            <Button Text="Leverroute starten"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="OnStartRouteClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
